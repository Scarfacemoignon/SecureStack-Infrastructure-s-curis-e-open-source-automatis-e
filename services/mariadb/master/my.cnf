[mysqld]
# ── Identité du serveur (UNIQUE dans le cluster) ──────────────
server-id                = 1

# ── Binary Log (journal de toutes les modifications) ──────────
log_bin                  = /var/log/mysql/mysql-bin.log
binlog_do_db             = appdb
binlog_format            = ROW
expire_logs_days         = 7

# ── Logs d'erreurs (lus par Wazuh) ────────────────────────────
log_error                = /var/log/mysql/error.log

# ── Slow Query Log (requêtes lentes > 2s) ─────────────────────
slow_query_log           = 1
slow_query_log_file      = /var/log/mysql/slow.log
long_query_time          = 2

# ── Performance ───────────────────────────────────────────────
innodb_buffer_pool_size  = 256M
max_connections          = 100

# ── Réseau ────────────────────────────────────────────────────
bind-address             = 0.0.0.0
